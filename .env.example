# Copia in `.env` (gitignored) e riempi. In CI questi vengono dagli Actions Secrets.
TELEGRAM_BOT_TOKEN=123456789:AA-your-botfather-token
TELEGRAM_CHAT_ID=123456789

# Phase 2
# SEMANTIC_SCHOLAR_API_KEY=your-s2-key

# Persistenza dello stato (data/) su un gist privato — vedi tools/state_store.py.
# Il repo e' pubblico, quindi lo stato (offset Telegram, seen-ids, profilo,
# cache vettori, log) vive in un gist SEGRETO (file state.b64), non su branch.
# In CI questi due valori vengono dagli Actions Secrets.
# GIST_ID = id del gist privato che contiene lo stato
GIST_ID=abcdef0123456789abcdef0123456789
# GIST_TOKEN = Personal Access Token con scope `gist` (lettura/scrittura del gist)
GIST_TOKEN=ghp_your-personal-access-token-with-gist-scope
