# Copy to `.env` (gitignored) and fill in. In CI these come from Actions Secrets.
TELEGRAM_BOT_TOKEN=123456789:AA-your-botfather-token
# Owner/admin chat id (receives /reports, /errors, error pushes and the digest
# heartbeat). In multi-user mode each user's own chat id is discovered at runtime.
TELEGRAM_CHAT_ID=123456789

# Stable secret used to derive anonymous user ids (u_<digest>) WITHOUT storing any
# nickname or raw Telegram id in the preference dataset. Generate a long random
# value in production and keep it stable (changing it rotates all anonymous ids).
# REQUIRED for a public deployment: set BOT_ENV=production (or
# REQUIRE_USER_ID_SECRET=1) to make the bot fail fast if this is missing/weak.
USER_ID_SECRET=change-me-to-a-long-random-secret

# Production guard: when set, a missing/weak USER_ID_SECRET aborts startup instead
# of only warning. Leave unset for local/dev.
# BOT_ENV=production
# REQUIRE_USER_ID_SECRET=1

# Optional dedicated key for encrypting delivery chat ids at rest in the user
# registry (data/user_registry.json). Falls back to USER_ID_SECRET when unset.
# REGISTRY_SECRET=another-long-random-secret

# Phase 2
# SEMANTIC_SCHOLAR_API_KEY=your-s2-key

# State persistence (data/) to a private gist — see tools/state_store.py.
# The repo is public, so state (Telegram offset, seen-ids, profiles, vector
# caches, the user registry, logs) lives in a SECRET gist (file state.b64), not on
# a branch. In CI these two values come from the Actions Secrets.
# GIST_ID = id of the private gist holding the state
GIST_ID=abcdef0123456789abcdef0123456789
# GIST_TOKEN = Personal Access Token with the `gist` scope (read/write the gist)
GIST_TOKEN=ghp_your-personal-access-token-with-gist-scope
